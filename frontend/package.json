{
  "name": "social-platform",
  "version": "1.0.0",
  "description": "Modular social networking platform combining Instagram, Twitter, WhatsApp, and LinkedIn features",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "socket": "cross-env NODE_ENV=development ts-node --project tsconfig.server.json src/server/socket-server.ts",
    "dev:all": "concurrently \"npm run dev\" \"npm run socket\"",
    "seed": "ts-node --project tsconfig.server.json scripts/seed-database.ts",
    "migrate:streak": "ts-node --project tsconfig.server.json scripts/migrate-streak-fields.ts"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "cookie": "^1.0.2",
    "date-fns": "^4.1.0",
    "framer-motion": "^11.18.2",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.561.0",
    "mongoose": "^8.8.3",
    "next": "^16.2.4",
    "next-themes": "^0.4.6",
    "pino": "^9.14.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^3.8.1",
    "set-cookie-parser": "^2.6.0",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.6.0",
    "zod": "^3.25.76",
    "zustand": "^5.0.1"
